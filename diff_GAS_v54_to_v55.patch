+function deleteOS(payload) {
+  const body = payload || {};
+  const idOs = String(body.id_os || body.ID_OS || '').trim();
+  if (!idOs) return { status: 'error', error: 'id_os obrigatório' };
+  const lock = LockService.getScriptLock();
+  lock.waitLock(30000);
+  try {
+    ensureOSHeaders_();
+    const sheet = getOrCreateSheet('ORDENS_SERVICO', HEADERS.ORDENS_SERVICO);
+    const data = sheet.getDataRange().getValues();
+    const headers = data[0] || HEADERS.ORDENS_SERVICO;
+    const idxId = headers.indexOf('id_os');
+    const idxAtivo = headers.indexOf('Ativo');
+    const idxUpdatedAt = headers.indexOf('Updated_At');
+    const idxUpdatedBy = headers.indexOf('Updated_By');
+    if (idxId < 0 || idxAtivo < 0) return { status: 'error', error: 'Colunas obrigatórias ausentes em ORDENS_SERVICO' };
+    for (let r = 1; r < data.length; r++) {
+      if (String(data[r][idxId] || '').trim() === idOs) {
+        const rowNum = r + 1;
+        const now = new Date().toISOString();
+        const updatedBy = body.updated_by || body.Updated_By || body.deletedBy || body.usuario_atual || 'sistema';
+        sheet.getRange(rowNum, idxAtivo + 1).setValue('NÃO');
+        if (idxUpdatedAt >= 0) sheet.getRange(rowNum, idxUpdatedAt + 1).setValue(now);
+        if (idxUpdatedBy >= 0) sheet.getRange(rowNum, idxUpdatedBy + 1).setValue(updatedBy);
+        return { status: 'ok', id_os: idOs };
+      }
+    }
+    return { status: 'error', error: 'OS não encontrada' };
+  } finally {
+    lock.releaseLock();
+  }
 }
 
