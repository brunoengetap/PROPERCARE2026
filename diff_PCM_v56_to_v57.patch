+async function deleteOSFromList(idOs) {
+  if (!idOs) return;
+  if (!confirm('Excluir esta OS? Ela sairá das listagens.')) return;
+  const session = window.PROPER_SESSION || {};
+  const tecnico = session.tecnico || {};
+  try {
+    await syncToGS('deleteOS', { id_os: idOs, updated_by: tecnico.nome || session.nome || 'admin' });
+    toast('OS excluída com sucesso.', 'success');
+    await renderOS();
+  } catch(e) {
+    if (e.message && e.message.includes('AUTH_GOOGLE')) { hubLogout(); return; }
+    toast('Erro ao excluir OS: ' + e.message, 'error');
+  }
+}
